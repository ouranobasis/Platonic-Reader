<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Platonic_Reader.Apology" 
             BackgroundColor="#f9f1cf"
             Title="APOLOGY">

    <StackLayout>
        <StackLayout>
            <Image Source="greekCoils.png"/>            
        </StackLayout>
        <ScrollView>
            <StackLayout x:Name="page" Margin="20,0">
                <Label x:Name="sentenceIndicator" HorizontalOptions="Center" FontSize="80" TextColor="#292b29" FontFamily="GFSBaskerville.ttf#GFS Porson" />
                <Label x:Name="sentence" FontSize="30" FontAttributes="Italic"/>
            </StackLayout>
        </ScrollView>

        <StackLayout Margin="20, 0" VerticalOptions="EndAndExpand" HorizontalOptions="Center" Orientation="Horizontal" BackgroundColor="Transparent">
            <Button Text="Back" x:Name="previous" Clicked="OnPreviousButtonClick" BackgroundColor="Transparent" FontAttributes="Bold" FontSize="20" TextColor="#999999"/>
            <Button Text="Next" x:Name="next" Clicked="OnNextButtonClick" BackgroundColor="Transparent" FontAttributes="Bold" FontSize="20" TextColor="#292b29"/>
        </StackLayout>
    </StackLayout>
</ContentPage>